FROM golang:1.25 AS build

WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/chatwoot ./cmd/chatwoot

FROM gcr.io/distroless/base-debian12:nonroot
COPY --from=build /out/chatwoot /chatwoot
ENTRYPOINT ["/chatwoot"]
